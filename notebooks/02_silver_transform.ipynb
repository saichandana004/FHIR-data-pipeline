from pyspark.sql.functions import *
from delta.tables import DeltaTable

def flatten_patient(df_bronze):
    """Parse JSON and extract structured columns."""
    return df_bronze.select(
        get_json_object("raw_json", "$.id").alias("patient_id"),
        get_json_object("raw_json", "$.gender").alias("gender"),
        get_json_object("raw_json", "$.birthDate").alias("birth_date"),
        get_json_object("raw_json", "$.name[0].family").alias("family_name"),
        get_json_object("raw_json", "$.name[0].given[0]").alias("given_name"),
        col("extraction_timestamp"),
        col("load_date")
    ).dropDuplicates(["patient_id"])

def apply_scd2(silver_table_name, new_df, key_col, compare_cols):
    """Apply SCD Type 2 logic using Delta MERGE."""
    
    new_df = new_df \
        .withColumn("scd_start_date", current_timestamp()) \
        .withColumn("scd_end_date", lit(None).cast("timestamp")) \
        .withColumn("is_current", lit(True))
    
    table_path = f"Tables/{silver_table_name}"
    
    if not DeltaTable.isDeltaTable(spark, table_path):
        new_df.write.format("delta").save(table_path)
        return
    
    delta_table = DeltaTable.forPath(spark, table_path)
    
    # Build condition string for detecting changes
    change_cond = " OR ".join([f"existing.{c} != updates.{c}" for c in compare_cols])
    
    delta_table.alias("existing").merge(
        new_df.alias("updates"),
        f"existing.{key_col} = updates.{key_col} AND existing.is_current = true"
    ).whenMatchedUpdate(
        condition=change_cond,
        set={"is_current": "false", "scd_end_date": "current_timestamp()"}
    ).whenNotMatchedInsertAll().execute()
    
    # Insert new versions for changed records
    changed = new_df.join(
        delta_table.toDF().filter("is_current = false and scd_end_date >= current_timestamp() - interval 1 minute"),
        key_col
    )
    if changed.count() > 0:
        changed.write.format("delta").mode("append").save(table_path)

# Process Patient
bronze_patient = spark.read.format("delta").load("Tables/bronze_patient")
silver_patient = flatten_patient(bronze_patient)
apply_scd2("silver_patient", silver_patient, "patient_id", ["gender", "family_name", "given_name"])
