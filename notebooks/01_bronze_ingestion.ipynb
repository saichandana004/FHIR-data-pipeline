import requests, json
from datetime import datetime, timedelta
from pyspark.sql import SparkSession
from pyspark.sql.functions import lit, current_timestamp

spark = SparkSession.builder.getOrCreate()

BASE_URL = "https://hapi.fhir.org/baseR4"
RESOURCES = ["Patient", "Encounter", "Observation", "Condition"]
LAKEHOUSE_PATH = "Files/raw"  # raw JSON storage

def fetch_resource_paginated(resource_name, date_str):
    """Fetch all pages for a resource on a given date."""
    url = f"{BASE_URL}/{resource_name}?_lastUpdated=ge{date_str}&_count=100"
    all_entries = []
    
    while url:
        response = requests.get(url, headers={"Accept": "application/fhir+json"})
        response.raise_for_status()
        bundle = response.json()
        
        entries = bundle.get("entry", [])
        all_entries.extend(entries)
        
        # Pagination: find next link
        url = next(
            (link["url"] for link in bundle.get("link", []) if link["rel"] == "next"),
            None
        )
    return all_entries

def ingest_bronze(resource_name, run_date):
    entries = fetch_resource_paginated(resource_name, run_date)
    
    # Save raw JSON to Files layer
    raw_path = f"{LAKEHOUSE_PATH}/{resource_name}/{run_date}/"
    for i, entry in enumerate(entries):
        dbutils.fs.put(
            f"{raw_path}record_{i}.json",
            json.dumps(entry),
            overwrite=True
        )
    
    # Convert to Spark DataFrame with metadata
    if entries:
        df = spark.createDataFrame([
            {"resource_id": e["resource"]["id"],
             "resource_type": resource_name,
             "raw_json": json.dumps(e["resource"]),
             "extraction_timestamp": datetime.utcnow().isoformat(),
             "api_url_or_params": f"{BASE_URL}/{resource_name}?_lastUpdated=ge{run_date}",
             "load_date": run_date}
            for e in entries
        ])
        
        # Write to Bronze Delta table
        df.write.format("delta") \
            .mode("append") \
            .option("mergeSchema", "true") \
            .save(f"Tables/bronze_{resource_name.lower()}")
        
        print(f"Loaded {len(entries)} {resource_name} records for {run_date}")

# Run for last 3 days
for days_back in range(3, 0, -1):
    run_date = (datetime.utcnow() - timedelta(days=days_back)).strftime("%Y-%m-%d")
    for resource in RESOURCES:
        ingest_bronze(resource, run_date)
