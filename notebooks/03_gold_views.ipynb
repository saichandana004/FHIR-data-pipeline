# Create analytical Gold views joining Silver tables
spark.sql("""
CREATE OR REPLACE VIEW gold_patient_encounter_summary AS
SELECT 
    p.patient_id,
    p.given_name || ' ' || p.family_name AS full_name,
    p.gender,
    p.birth_date,
    COUNT(DISTINCT e.encounter_id) AS total_encounters,
    COUNT(DISTINCT c.condition_id) AS total_conditions,
    COUNT(DISTINCT o.observation_id) AS total_observations,
    MAX(e.encounter_date) AS last_encounter_date
FROM silver_patient p
LEFT JOIN silver_encounter e ON p.patient_id = e.patient_id AND e.is_current = true
LEFT JOIN silver_condition c ON p.patient_id = c.patient_id AND c.is_current = true
LEFT JOIN silver_observation o ON p.patient_id = o.patient_id AND o.is_current = true
WHERE p.is_current = true
GROUP BY p.patient_id, p.given_name, p.family_name, p.gender, p.birth_date
""")

spark.sql("""
CREATE OR REPLACE VIEW gold_condition_prevalence AS
SELECT
    code_display AS condition_name,
    COUNT(DISTINCT patient_id) AS patient_count,
    COUNT(*) AS total_records,
    MIN(onset_date) AS earliest_onset,
    MAX(onset_date) AS latest_onset
FROM silver_condition
WHERE is_current = true
GROUP BY code_display
ORDER BY patient_count DESC
""")
